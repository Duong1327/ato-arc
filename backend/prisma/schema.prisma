// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  // For production, change provider to "postgresql" and configure DATABASE_URL in .env
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Invoice {
  id           String        @id
  amount       Float
  token        String
  recipient    String
  type         String        // "milestone" or "direct"
  milestoneId  Int?
  status       String        // "PENDING", "COMPLIANCE_APPROVED", "SETTLED", "FAILED"
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Transaction {
  id               String   @id // Circle transactionId or on-chain tx hash
  invoiceId        String
  invoice          Invoice  @relation(fields: [invoiceId], references: [id])
  walletId         String
  amount           Float
  status           String   // "PENDING", "SUCCESS", "FAILED"
  blockchainTxHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model WebhookLog {
  id           String   @id @default(uuid())
  eventId      String   @unique // Circle event ID for idempotency/duplicate checking
  eventType    String   // e.g. "transfers.updated" or "wallets.transaction.succeeded"
  payload      String   // Raw payload JSON
  status       String   // "PROCESSED", "DUPLICATE", "FAILED", "IGNORED"
  errorMessage String?
  createdAt    DateTime @default(now())
}

model BankAccount {
  id            String            @id
  bankName      String
  accountNumber String
  routingNumber String
  status        String            // "ACTIVE", "PENDING", "FAILED"
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  wires         WireTransaction[]
}

model WireTransaction {
  id            String      @id // Circle payout/deposit transferId or simulated wire ID
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id])
  amount        Float
  currency      String      // "USD", "EUR"
  direction     String      // "INFLOW", "OUTFLOW"
  status        String      // "PENDING", "SUCCESS", "FAILED"
  trackingRef   String?     // Wire reference code
  usdcTxHash    String?     // Minted USDC Tx hash or burned USDC Tx hash
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model AgentPolicy {
  id                             String   @id @default("agent_gamma_allocator")
  spendingLimitDailyUSDC         Float
  dailyVolumeSpentUSDC           Float    @default(0.0)
  transactionFrequencyCapPerHour Int
  addressAllowlist               String   // Comma-separated EVM addresses
  enforced                       Boolean  @default(true)
  updatedAt                      DateTime @updatedAt
}

model YieldRate {
  id                     String   @id @default("rates")
  baseAave               Float    @default(0.0)
  baseComp               Float    @default(0.0)
  arbAave                Float    @default(0.0)
  arbComp                Float    @default(0.0)
  arcYield               Float    @default(0.0)
  minYieldDifferential   Float    @default(1.5) // Minimum differential in percentage (e.g. 1.5%)
  bridgeSizeCapUSDC      Float    @default(10000.0) // Max USDC allowed to bridge in a single sweep
  slippageLimitPercent   Float    @default(0.5) // Max slippage allowed (e.g. 0.5%)
  isSweepEnabled         Boolean  @default(true)
  updatedAt              DateTime @updatedAt
}

model BridgeLog {
  id             String   @id @default(uuid())
  sourceChain    String   // "Base" or "Arbitrum"
  destChain      String   // "Arc"
  amountUSDC     Float
  yieldDiff      Float
  status         String   // "PENDING", "COMPLETED", "FAILED"
  txHash         String?
  cctpMessage    String?  // CCTP message bytes or attestation request
  createdAt      DateTime @default(now())
}
